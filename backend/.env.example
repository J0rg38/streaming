# Copia este archivo a .env y ajusta los valores a tu instalación local.
PORT=4000

# Conexión PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=vod

# Carpeta raíz donde viven tus videos. El backend SOLO servirá archivos
# que estén dentro de esta carpeta (protección contra path traversal).
MEDIA_ROOT=/ruta/a/tus/videos

# --- Seguridad / Autenticación ---------------------------------------------
JWT_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio
JWT_EXPIRES=7d
ADMIN_EMAIL=admin@vod.local
ADMIN_PASSWORD=CambiaEstaClave123!
ADMIN_NAME=Administrador
CLIENT_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
MAX_UPLOAD_GB=50

# --- Almacenamiento multi-disco (opcional) ---------------------------------
# Lista de discos donde guardar el contenido (JSON en una sola línea). El disco
# por defecto (MEDIA_ROOT) se añade solo si no lo incluyes. Cada disco necesita
# una ruta ya montada y con permisos de escritura.
# MEDIA_DISKS=[{"id":"disk1","label":"Disco 1","path":"/mnt/disk1"},{"id":"disk2","label":"Disco 2","path":"/mnt/disk2"}]

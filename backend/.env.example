# ============================================================================
#  backend/.env.example — plantilla de variables de entorno del backend.
#
#  Cómo usarlo:
#    cp .env.example .env      (y ajusta los valores)
#
#  Los valores de abajo son para DESARROLLO LOCAL. Las notas "PROD:" indican
#  qué cambiar en el servidor de producción. Este archivo SÍ va en git; el
#  .env real NO (está en .gitignore porque tiene secretos).
# ============================================================================

# Puerto del backend (Node/Express).
PORT=4000

# --- Conexión PostgreSQL ----------------------------------------------------
# En local necesitas PostgreSQL corriendo y la BD creada:
#   createdb vod   &&   psql -d vod -f database/schema.sql
#   y luego cada database/migration_*.sql en orden.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=vod

# --- Almacenamiento de media ------------------------------------------------
# Carpeta raíz por defecto donde se guardan videos/imágenes/HLS. El backend SOLO
# sirve archivos dentro de los discos configurados (anti path-traversal).
# PROD: p.ej. /var/www/streaming/backend/media
MEDIA_ROOT=/ruta/a/tus/videos

# Multi-disco (OPCIONAL). JSON en UNA sola línea. El disco por defecto (MEDIA_ROOT)
# se añade solo si no lo incluyes aquí. Cada "path" debe estar montado y con permisos
# de escritura (en producción con SELinux, etiqueta sus subcarpetas movies/series/
# images/hls con httpd_sys_rw_content_t — ver DEPLOY.md).
# MEDIA_DISKS=[{"id":"disk1","label":"Primer Disco","path":"/home"},{"id":"disk2","label":"Segundo Disco","path":"/mnt/vod2"}]

# Rutas de ffmpeg/ffprobe (OPCIONAL). Por defecto usa ffmpeg-static/ffprobe-static
# (ya incluidos). Defínelas solo si quieres usar los binarios del sistema.
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Tamaño máximo por archivo de video subido (GB).
MAX_UPLOAD_GB=50

# --- Seguridad / Autenticación ---------------------------------------------
# JWT_SECRET: cadena larga y ALEATORIA (no la compartas). Genera una con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio
JWT_EXPIRES=7d

# Admin que se crea automáticamente al arrancar si no existe (seed).
ADMIN_EMAIL=admin@vod.local
ADMIN_PASSWORD=CambiaEstaClave123!
ADMIN_NAME=Administrador

# Origen permitido para CORS (la URL del frontend).
# DEV:  http://localhost:5173
# PROD: https://vod.cisne.com.pe
CLIENT_ORIGIN=http://localhost:5173

# Cookies "secure" (solo se envían por HTTPS).
# DEV:  false (estás en http://localhost)
# PROD: true  (obligatorio con HTTPS; requiere 'trust proxy', ya configurado en index.js)
COOKIE_SECURE=false

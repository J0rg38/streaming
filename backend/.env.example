# Copia este archivo a .env y ajusta los valores a tu instalación local.
PORT=4000

# Conexión PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=vod

# Carpeta raíz donde viven tus videos. El backend SOLO servirá archivos
# que estén dentro de esta carpeta (protección contra path traversal).
MEDIA_ROOT=/ruta/a/tus/videos

# --- Seguridad / Autenticación ---------------------------------------------
JWT_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio
JWT_EXPIRES=7d
ADMIN_EMAIL=admin@vod.local
ADMIN_PASSWORD=CambiaEstaClave123!
ADMIN_NAME=Administrador
CLIENT_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
MAX_UPLOAD_GB=50
